PROJECT_NAME=FinLedger.AI
PROJECT_ENV=development
PROJECT_VERSION=0.1.0
LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=finledger_docfinqa
QDRANT_USE_HTTPS=false
QDRANT_API_KEY=
VECTOR_BACKEND=qdrant
FAISS_INDEX_PATH=data/processed/faiss/docfinqa.index
DOCFINQA_TRAIN_PATH=data/raw/docfinqa_train.json
DOCFINQA_VALIDATION_PATH=data/raw/docfinqa_validation.json
DOCFINQA_TEST_PATH=data/raw/docfinqa_test.json
CHUNK_PARENT_SIZE=3000
CHUNK_CHILD_SIZE=600
CHUNK_OVERLAP=120
MAX_CONTEXTS=6
TEMPERATURE=0.0
TOP_K=20
RETRIEVAL_MODE=parent_child
RETRIEVAL_VECTOR_WEIGHT=0.75
RETRIEVAL_KEYWORD_WEIGHT=0.25
COMPRESSION_TOP_N=8
PARENT_CHUNKS_PATH=data/processed/chunks/parent_chunks.jsonl
CHILD_CHUNKS_PATH=data/processed/chunks/child_chunks.jsonl
EVALUATION_SAMPLE_SIZE=50
EVALUATION_OUTPUT_PATH=data/processed/evaluation/latest_report.json
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=
STREAMLIT_PORT=8501
